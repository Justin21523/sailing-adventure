    "react-dom": "^18.3.1",
    "three": "^0.164.1",
    "zustand": "^4.5.2",
    "simplex-noise": "^4.0.1",
    "leva": "^0.9.35"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.0.3",
    "@gltf-transform/functions": "^4.0.3",
    "@react-three/test-renderer": "^8.2.1",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.164.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
